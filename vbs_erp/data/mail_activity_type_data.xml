<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="activity_type_lien_he_khach" model="mail.activity.type">
            <field name="name">Liên hệ khách hàng</field>
            <field name="icon">fa-phone</field>
            <field name="delay_count">1</field>
            <field name="delay_unit">days</field>
            <field name="res_model">vbs.garment</field>
        </record>

        <record id="activity_type_vai_ve" model="mail.activity.type">
            <field name="name">Vải đã về</field>
            <field name="icon">fa-truck</field>
            <field name="delay_count">0</field>
            <field name="delay_unit">days</field>
            <field name="res_model">vbs.fabric.order</field>
        </record>

        <record id="activity_type_sla_overdue" model="mail.activity.type">
            <field name="name">Quá hạn SLA</field>
            <field name="icon">fa-exclamation-triangle</field>
            <field name="delay_count">0</field>
            <field name="delay_unit">days</field>
            <field name="res_model">vbs.garment</field>
        </record>
    </data>

    <!-- Automation: tạo activity khi garment state thay đổi -->
    <data noupdate="0">
        <record id="automation_fabric_arrived" model="base.automation">
            <field name="name">VBS: Báo vải đã về</field>
            <field name="model_id" ref="model_vbs_fabric_order"/>
            <field name="trigger">on_write</field>
            <field name="filter_domain">[('state', '=', 'da_ve')]</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
