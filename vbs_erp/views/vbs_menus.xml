<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ ẨN CÁC APP GỐC KHÔNG CẦN THIẾT ============ -->

    <!-- Ẩn "Lập lịch" standalone (đã có dưới VBS → Sản xuất) -->
    <record id="vbs_planning.menu_planning_root" model="ir.ui.menu">
        <field name="active">False</field>
    </record>

    <!-- Ẩn "Nhân viên" standalone (sẽ đưa vào VBS) -->
    <record id="hr.menu_hr_root" model="ir.ui.menu">
        <field name="active">False</field>
    </record>

    <!-- Ẩn "Hóa đơn" (VBS chưa dùng invoicing) -->
    <record id="account.menu_finance" model="ir.ui.menu">
        <field name="active">False</field>
    </record>

    <!-- Ẩn "Trình theo dõi Liên kết" (utm, không dùng) -->
    <record id="utm.menu_link_tracker_root" model="ir.ui.menu">
        <field name="active">False</field>
    </record>

    <!-- Ẩn "Tests" (dev only) -->
    <record id="base.menu_tests" model="ir.ui.menu">
        <field name="active">False</field>
    </record>

    <!-- ============ ROOT MENU VBS ============ -->

    <!-- Root menu VBS -->
    <menuitem id="menu_vbs_root"
              name="VBS"
              sequence="10"/>

    <!-- Đơn hàng -->
    <menuitem id="menu_vbs_orders"
              name="Đơn hàng"
              parent="menu_vbs_root"
              action="action_vbs_sale_order"
              sequence="10"
              groups="vbs_erp.group_vbs_admin,vbs_erp.group_vbs_sale,vbs_erp.group_vbs_accountant"/>

    <!-- Liên hệ khách hàng -->
    <menuitem id="menu_vbs_contact_log"
              name="Liên hệ khách hàng"
              parent="menu_vbs_root"
              action="action_vbs_contact_log"
              sequence="15"
              groups="vbs_erp.group_vbs_admin,vbs_erp.group_vbs_sale,vbs_erp.group_vbs_office"/>

    <!-- Sản xuất -->
    <menuitem id="menu_vbs_production"
              name="Sản xuất"
              parent="menu_vbs_root"
              sequence="20"/>

    <menuitem id="menu_vbs_garments"
              name="Theo dõi đồ"
              parent="menu_vbs_production"
              action="action_vbs_garment"
              sequence="10"
              groups="vbs_erp.group_vbs_admin,vbs_erp.group_vbs_sale,vbs_erp.group_vbs_workshop,vbs_erp.group_vbs_office"/>

    <menuitem id="menu_vbs_planning"
              name="Lịch làm việc"
              parent="menu_vbs_production"
              action="vbs_planning.action_planning_slot"
              sequence="20"
              groups="vbs_erp.group_vbs_admin,vbs_erp.group_vbs_sale,vbs_erp.group_vbs_workshop,vbs_erp.group_vbs_office"/>

    <!-- Nhân viên -->
    <menuitem id="menu_vbs_employees"
              name="Nhân viên"
              parent="menu_vbs_root"
              action="hr.open_view_employee_list_my"
              sequence="25"
              groups="vbs_erp.group_vbs_admin"/>

    <!-- Kho vải -->
    <menuitem id="menu_vbs_fabric"
              name="Kho vải"
              parent="menu_vbs_root"
              sequence="30"/>

    <menuitem id="menu_vbs_fabric_order"
              name="Đặt vải"
              parent="menu_vbs_fabric"
              action="action_vbs_fabric_order"
              sequence="10"
              groups="vbs_erp.group_vbs_admin,vbs_erp.group_vbs_warehouse,vbs_erp.group_vbs_sale"/>

    <menuitem id="menu_vbs_fabric_stock"
              name="Tồn kho"
              parent="menu_vbs_fabric"
              action="action_vbs_fabric_stock"
              sequence="20"
              groups="vbs_erp.group_vbs_admin,vbs_erp.group_vbs_warehouse,vbs_erp.group_vbs_sale"/>

    <menuitem id="menu_vbs_fabric_type"
              name="Danh mục vải"
              parent="menu_vbs_fabric"
              action="action_vbs_fabric_type"
              sequence="30"
              groups="vbs_erp.group_vbs_admin,vbs_erp.group_vbs_accountant"/>

    <!-- Cấu hình (Admin only) -->
    <menuitem id="menu_vbs_config"
              name="Cấu hình"
              parent="menu_vbs_root"
              sequence="100"
              groups="vbs_erp.group_vbs_admin"/>

    <menuitem id="menu_vbs_pricing_product"
              name="Bảng giá gia công"
              parent="menu_vbs_config"
              action="action_vbs_pricing_product"
              sequence="10"
              groups="vbs_erp.group_vbs_admin,vbs_erp.group_vbs_accountant"/>

    <menuitem id="menu_vbs_sla"
              name="Cấu hình SLA"
              parent="menu_vbs_config"
              action="action_vbs_sla_config"
              sequence="20"
              groups="vbs_erp.group_vbs_admin"/>

    <menuitem id="menu_vbs_stage_template"
              name="Template công đoạn"
              parent="menu_vbs_config"
              action="action_vbs_stage_template"
              sequence="25"
              groups="vbs_erp.group_vbs_admin,vbs_erp.group_vbs_workshop"/>

    <menuitem id="menu_vbs_pattern"
              name="Mã rập"
              parent="menu_vbs_config"
              action="action_vbs_pattern"
              sequence="30"
              groups="vbs_erp.group_vbs_admin,vbs_erp.group_vbs_accountant,vbs_erp.group_vbs_sale,vbs_erp.group_vbs_workshop,vbs_erp.group_vbs_office"/>

</odoo>
