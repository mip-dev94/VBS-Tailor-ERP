<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ CONTACT LOG LIST ============ -->
    <record id="view_vbs_contact_log_list" model="ir.ui.view">
        <field name="name">vbs.contact.log.list</field>
        <field name="model">vbs.contact.log</field>
        <field name="arch" type="xml">
            <list string="Nhật ký liên hệ"
                  decoration-muted="tinh_trang == 'da_lien_he'">
                <field name="date_contact"/>
                <field name="partner_id"/>
                <field name="garment_id" optional="show"/>
                <field name="noi_dung"/>
                <field name="ket_qua"/>
                <field name="tinh_trang" widget="badge"
                       decoration-warning="tinh_trang == 'cho_lien_he'"
                       decoration-success="tinh_trang == 'da_lien_he'"/>
                <field name="user_id" optional="show"/>
            </list>
        </field>
    </record>

    <!-- ============ CONTACT LOG FORM ============ -->
    <record id="view_vbs_contact_log_form" model="ir.ui.view">
        <field name="name">vbs.contact.log.form</field>
        <field name="model">vbs.contact.log</field>
        <field name="arch" type="xml">
            <form string="Liên hệ khách hàng">
                <header>
                    <field name="tinh_trang" widget="statusbar"
                           statusbar_visible="cho_lien_he,da_lien_he"/>
                </header>
                <sheet>
                    <group>
                        <group string="Thông tin liên hệ">
                            <field name="date_contact"/>
                            <field name="partner_id"/>
                            <field name="garment_id"
                                   domain="[('partner_id', '=', partner_id)]"/>
                            <field name="order_id" readonly="1"/>
                            <field name="user_id"/>
                        </group>
                        <group string="Nội dung &amp; Kết quả">
                            <field name="tinh_trang"/>
                            <field name="noi_dung"/>
                            <field name="ket_qua"/>
                        </group>
                    </group>
                    <group string="Ghi chú">
                        <field name="note" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============ CONTACT LOG SEARCH ============ -->
    <record id="view_vbs_contact_log_search" model="ir.ui.view">
        <field name="name">vbs.contact.log.search</field>
        <field name="model">vbs.contact.log</field>
        <field name="arch" type="xml">
            <search string="Tìm nhật ký liên hệ">
                <field name="partner_id"/>
                <field name="noi_dung"/>
                <field name="garment_id"/>
                <separator/>
                <filter string="Chờ liên hệ" name="cho_lien_he"
                        domain="[('tinh_trang', '=', 'cho_lien_he')]"/>
                <filter string="Đã liên hệ" name="da_lien_he"
                        domain="[('tinh_trang', '=', 'da_lien_he')]"/>
                <separator/>
                <filter string="Hôm nay" name="today"
                        domain="[('date_contact', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <separator/>
                <group>
                    <filter string="Khách hàng" name="group_partner" domain="[]"
                            context="{'group_by': 'partner_id'}"/>
                    <filter string="Tình trạng" name="group_status" domain="[]"
                            context="{'group_by': 'tinh_trang'}"/>
                    <filter string="Ngày" name="group_date" domain="[]"
                            context="{'group_by': 'date_contact:week'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============ CONTACT LOG ACTION ============ -->
    <record id="action_vbs_contact_log" model="ir.actions.act_window">
        <field name="name">Nhật ký liên hệ</field>
        <field name="res_model">vbs.contact.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_vbs_contact_log_search"/>
        <field name="context">{'search_default_cho_lien_he': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Chưa có nhật ký liên hệ</p>
            <p>Ghi lại mỗi lần liên hệ khách hàng về đồ may.</p>
        </field>
    </record>

</odoo>
