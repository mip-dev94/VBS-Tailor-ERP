<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ PRICING PRODUCT (Bảng giá gia công) ============ -->
    <record id="view_vbs_pricing_product_list" model="ir.ui.view">
        <field name="name">vbs.pricing.product.list</field>
        <field name="model">vbs.pricing.product</field>
        <field name="arch" type="xml">
            <list string="Bảng giá gia công" editable="bottom">
                <field name="product_type"/>
                <field name="labor_cost"/>
                <field name="note" optional="show"/>
            </list>
        </field>
    </record>

    <record id="action_vbs_pricing_product" model="ir.actions.act_window">
        <field name="name">Bảng giá gia công</field>
        <field name="res_model">vbs.pricing.product</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Chưa có bảng giá nào</p>
            <p>Nhập phí gia công cho từng loại sản phẩm.</p>
        </field>
    </record>

</odoo>
