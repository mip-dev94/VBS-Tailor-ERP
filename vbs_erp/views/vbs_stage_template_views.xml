<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vbs_stage_template_list" model="ir.ui.view">
        <field name="name">vbs.stage.template.list</field>
        <field name="model">vbs.stage.template</field>
        <field name="arch" type="xml">
            <list string="Template công đoạn" editable="bottom">
                <field name="garment_type"/>
                <field name="sequence" widget="handle"/>
                <field name="step_type"/>
                <field name="note"/>
            </list>
        </field>
    </record>

    <record id="view_vbs_stage_template_search" model="ir.ui.view">
        <field name="name">vbs.stage.template.search</field>
        <field name="model">vbs.stage.template</field>
        <field name="arch" type="xml">
            <search string="Tìm template">
                <field name="garment_type"/>
                <field name="step_type"/>
                <group>
                    <filter string="Loại đồ" name="group_garment_type" domain="[]"
                            context="{'group_by': 'garment_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_vbs_stage_template" model="ir.actions.act_window">
        <field name="name">Template công đoạn</field>
        <field name="res_model">vbs.stage.template</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_vbs_stage_template_search"/>
        <field name="context">{'search_default_group_garment_type': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo template công đoạn
            </p>
            <p>
                Khi tạo đồ mới, các công đoạn sẽ tự động được tạo theo template của loại đồ tương ứng.
            </p>
        </field>
    </record>

</odoo>
