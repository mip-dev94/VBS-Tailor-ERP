<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Module category -->
    <record id="module_category_vbs" model="ir.module.category">
        <field name="name">VBS</field>
        <field name="sequence">100</field>
    </record>

    <!--
        Odoo 19: mỗi "privilege" = 1 hàng trong tab Access Rights.
        Mỗi nhóm VBS là độc lập (không loại trừ nhau), nên mỗi nhóm
        có 1 privilege riêng để xuất hiện dưới dạng checkbox riêng biệt.
    -->

    <record id="priv_vbs_admin" model="res.groups.privilege">
        <field name="name">Quản trị VBS</field>
        <field name="sequence">10</field>
        <field name="category_id" ref="module_category_vbs"/>
    </record>

    <record id="priv_vbs_accountant" model="res.groups.privilege">
        <field name="name">Kế toán VBS</field>
        <field name="sequence">20</field>
        <field name="category_id" ref="module_category_vbs"/>
    </record>

    <record id="priv_vbs_sale" model="res.groups.privilege">
        <field name="name">Sale VBS</field>
        <field name="sequence">30</field>
        <field name="category_id" ref="module_category_vbs"/>
    </record>

    <record id="priv_vbs_warehouse" model="res.groups.privilege">
        <field name="name">Kho VBS</field>
        <field name="sequence">40</field>
        <field name="category_id" ref="module_category_vbs"/>
    </record>

    <record id="priv_vbs_workshop" model="res.groups.privilege">
        <field name="name">Xưởng VBS</field>
        <field name="sequence">50</field>
        <field name="category_id" ref="module_category_vbs"/>
    </record>

    <record id="priv_vbs_office" model="res.groups.privilege">
        <field name="name">Văn phòng VBS</field>
        <field name="sequence">60</field>
        <field name="category_id" ref="module_category_vbs"/>
    </record>

    <!-- Groups -->
    <record id="group_vbs_admin" model="res.groups">
        <field name="name">Quản trị VBS</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="priv_vbs_admin"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <record id="group_vbs_accountant" model="res.groups">
        <field name="name">Kế toán VBS</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="priv_vbs_accountant"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_vbs_sale" model="res.groups">
        <field name="name">Sale VBS</field>
        <field name="sequence">30</field>
        <field name="privilege_id" ref="priv_vbs_sale"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_vbs_warehouse" model="res.groups">
        <field name="name">Kho VBS</field>
        <field name="sequence">40</field>
        <field name="privilege_id" ref="priv_vbs_warehouse"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_vbs_workshop" model="res.groups">
        <field name="name">Xưởng VBS</field>
        <field name="sequence">50</field>
        <field name="privilege_id" ref="priv_vbs_workshop"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_vbs_office" model="res.groups">
        <field name="name">Văn phòng VBS</field>
        <field name="sequence">60</field>
        <field name="privilege_id" ref="priv_vbs_office"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
</odoo>
