<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="ir_cron_vbs_sla_check" model="ir.cron">
        <field name="name">VBS: Kiểm tra SLA hàng ngày</field>
        <field name="model_id" ref="model_vbs_garment"/>
        <field name="state">code</field>
        <field name="code">model._check_sla()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_vbs_fitting_reminder" model="ir.cron">
        <field name="name">VBS: Nhắc hẹn thử đồ hàng ngày</field>
        <field name="model_id" ref="model_vbs_garment"/>
        <field name="state">code</field>
        <field name="code">model._check_fitting_reminder()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>
</odoo>
