<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Action mở danh sách đồ đã dùng rập này (từ smart button) -->
    <record id="action_vbs_pattern_garments" model="ir.actions.act_window">
        <field name="name">Đồ đã may</field>
        <field name="res_model">vbs.garment</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('pattern_id', '=', active_id)]</field>
        <field name="context">{'default_pattern_id': active_id}</field>
    </record>

    <!-- Inherit pattern form: thêm garment smart button + preferred_fabric_type_id -->
    <record id="view_vbs_pattern_form_garment" model="ir.ui.view">
        <field name="name">vbs.pattern.form.garment</field>
        <field name="model">vbs.pattern</field>
        <field name="inherit_id" ref="vbs_config.view_vbs_pattern_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="%(action_vbs_pattern_garments)d" type="action"
                        class="oe_stat_button" icon="fa-scissors">
                    <field name="garment_count" widget="statinfo" string="Đồ đã may"/>
                </button>
            </div>
            <field name="fabric_meters_std" position="before">
                <field name="preferred_fabric_type_id"/>
            </field>
            <field name="date_created" position="after">
                <field name="last_used_date" readonly="1"/>
            </field>
        </field>
    </record>

    <!-- Inherit pattern list: thêm cột garment_count + preferred_fabric_type_id -->
    <record id="view_vbs_pattern_list_garment" model="ir.ui.view">
        <field name="name">vbs.pattern.list.garment</field>
        <field name="model">vbs.pattern</field>
        <field name="inherit_id" ref="vbs_config.view_vbs_pattern_list"/>
        <field name="arch" type="xml">
            <field name="fabric_meters_std" position="before">
                <field name="preferred_fabric_type_id" optional="show"/>
            </field>
            <field name="fabric_meters_std" position="after">
                <field name="garment_count" string="Số đồ" readonly="1"/>
                <field name="last_used_date" optional="show"/>
            </field>
        </field>
    </record>

</odoo>
