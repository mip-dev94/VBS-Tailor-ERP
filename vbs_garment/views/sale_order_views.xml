<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Action đơn hàng VBS -->
    <record id="action_vbs_sale_order" model="ir.actions.act_window">
        <field name="name">Đơn hàng</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{'default_order_type': 'b2c'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Tạo đơn hàng đầu tiên</p>
            <p>Quản lý đơn hàng may đo khách hàng VBS.</p>
        </field>
    </record>

    <!-- Inherit sale.order form -->
    <record id="view_sale_order_form_vbs" model="ir.ui.view">
        <field name="name">sale.order.form.vbs</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Smart buttons -->
            <div name="button_box" position="inside">
                <button name="action_view_garments" type="object"
                        class="oe_stat_button" icon="fa-tshirt"
                        invisible="garment_count == 0">
                    <field name="garment_count" widget="statinfo" string="Đồ may"/>
                </button>
                <button name="action_view_patterns" type="object"
                        class="oe_stat_button" icon="fa-cut"
                        invisible="pattern_count == 0 or not partner_id">
                    <field name="pattern_count" widget="statinfo" string="Rập khách"/>
                </button>
                <button name="action_view_fabric_orders" type="object"
                        class="oe_stat_button" icon="fa-shopping-cart"
                        invisible="fabric_order_count == 0">
                    <field name="fabric_order_count" widget="statinfo" string="Đặt vải"/>
                </button>
            </div>

            <!-- Fashion state + dual confirm buttons in header -->
            <field name="state" position="before">
                <!-- Nút xác nhận của Sale -->
                <button name="action_sale_confirm" type="object"
                        string="✓ Sale xác nhận" class="oe_highlight"
                        invisible="fashion_state != 'dang_xu_ly' or sale_confirmed"
                        groups="vbs_base.group_vbs_admin,vbs_base.group_vbs_sale"/>
                <!-- Nút xác nhận của Kế toán -->
                <button name="action_accountant_confirm" type="object"
                        string="✓ Kế toán xác nhận" class="oe_highlight"
                        invisible="fashion_state != 'dang_xu_ly' or accountant_confirmed"
                        groups="vbs_base.group_vbs_admin,vbs_base.group_vbs_accountant"/>
                <!-- Badge trạng thái xác nhận -->
                <span class="badge rounded-pill text-bg-success ms-1"
                      invisible="not sale_confirmed or fashion_state != 'dang_xu_ly'">Sale ✓</span>
                <span class="badge rounded-pill text-bg-info ms-1"
                      invisible="not accountant_confirmed or fashion_state != 'dang_xu_ly'">Kế toán ✓</span>
                <field name="sale_confirmed" invisible="1"/>
                <field name="accountant_confirmed" invisible="1"/>
                <field name="fashion_state" widget="statusbar"
                       statusbar_visible="dat_hang,dang_xu_ly,hoan_thanh"/>
            </field>

            <!-- Fields ẩn cho invisible conditions -->
            <field name="partner_id" position="before">
                <field name="can_start_production" invisible="1"/>
                <field name="fabric_order_count" invisible="1"/>
            </field>

            <!-- Loại đơn + tiền tệ + thanh toán rõ ràng (3 dòng) -->
            <field name="partner_id" position="after">
                <field name="order_type"/>
                <field name="b2b_type" invisible="order_type != 'b2b'"
                       required="order_type == 'b2b'"/>
                <field name="payment_state" widget="badge"
                       decoration-danger="payment_state == 'chua_tt'"
                       decoration-warning="payment_state == 'tt_1_phan'"
                       decoration-success="payment_state == 'tt_toan_bo'"/>
                <field name="currency_id" invisible="1"/>
                <field name="amount_total" string="Tổng đơn" readonly="1" widget="monetary"
                       options="{'currency_field': 'currency_id'}"/>
                <field name="amount_paid" string="Đã thanh toán" readonly="1" widget="monetary"
                       options="{'currency_field': 'currency_id'}"/>
                <field name="amount_remaining" string="Còn lại" readonly="1" widget="monetary"
                       options="{'currency_field': 'currency_id'}"
                       decoration-danger="amount_remaining &gt; 0"
                       decoration-success="amount_remaining == 0"/>
            </field>

            <!-- Đổi tên pricelist_id gốc thành Tiền tệ (tránh duplicate) -->
            <field name="pricelist_id" position="attributes">
                <attribute name="string">Tiền tệ</attribute>
                <attribute name="options">{'no_create': True}</attribute>
            </field>

            <!-- Bỏ Payment Terms — VBS Tailor quản lý thanh toán theo record -->
            <field name="payment_term_id" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>

            <!-- Loại khỏi dropdown partner các internal user (staff/admin) -->
            <field name="partner_id" position="attributes">
                <attribute name="domain">[('user_ids', '=', False)]</attribute>
            </field>

            <!-- Đổi "Order Lines" → "Đơn hàng" -->
            <xpath expr="//page[@name='order_lines']" position="attributes">
                <attribute name="string">Đơn hàng</attribute>
            </xpath>

            <!-- Thêm discount -->
            <xpath expr="//page[@name='order_lines']//list//field[@name='price_unit']" position="after">
                <field name="discount" optional="show"/>
            </xpath>
            <!-- Ẩn Delivered và Invoiced -->
            <xpath expr="//page[@name='order_lines']//list//field[@name='qty_delivered']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//page[@name='order_lines']//list//field[@name='qty_invoiced']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>

            <!-- Thêm cột set_type, garment_type, garment_count + nút tạo LSX per-line -->
            <xpath expr="//page[@name='order_lines']//list//field[@name='product_template_id']" position="after">
                <field name="set_type" optional="show"/>
                <field name="garment_type" optional="show"/>
                <field name="garment_count" string="LSX" optional="show"/>
                <button name="action_create_garments" type="object"
                        string="Tạo LSX" icon="fa-industry"
                        class="btn-link" title="Tạo lệnh sản xuất từ dòng này (yêu cầu ≥70% thanh toán)"
                        invisible="garment_count &gt; 0 or not garment_type"/>
                <button name="action_view_line_garments" type="object"
                        string="Xem LSX" icon="fa-tshirt"
                        class="btn-link"
                        invisible="garment_count == 0"/>
                <button name="action_compute_line_price" type="object"
                        string="Tính giá" icon="fa-calculator"
                        class="btn-link" title="Tính giá từ LSX → cập nhật đơn giá dòng này"
                        invisible="garment_count == 0"/>
            </xpath>

            <!-- Notebook 1 — Tab Đồ may sau Thành phẩm -->
            <xpath expr="//page[@name='order_lines']" position="after">
                <page string="Đồ may (tổng hợp)" name="vbs_garments">
                    <div class="mb-2">
                        <button name="action_launch_production" type="object"
                                string="Nhảy lệnh sản xuất"
                                class="btn btn-primary"
                                icon="fa-industry"
                                confirm="Xác nhận tạo lệnh sản xuất cho tất cả dòng chưa có LSX? Thao tác này không thể hoàn tác."
                                invisible="not can_start_production"
                                groups="vbs_base.group_vbs_admin,vbs_base.group_vbs_sale,vbs_base.group_vbs_office"/>
                        <span class="text-muted ms-2"
                              invisible="fashion_state != 'dang_xu_ly' or can_start_production">
                            Cần thanh toán ≥ 70% để nhảy lệnh sản xuất
                        </span>
                    </div>
                    <field name="garment_ids">
                        <list create="false" delete="false">
                            <field name="sequence" widget="handle"/>
                            <field name="garment_type"/>
                            <field name="detail"/>
                            <field name="set_type" optional="show"/>
                            <field name="set_code" optional="hide"/>
                            <field name="state" widget="badge"
                                   decoration-warning="state == 'lan_2'"
                                   decoration-primary="state == 'luoc'"
                                   decoration-success="state == 'hoan_thien'"/>
                            <field name="location" widget="badge"
                                   decoration-warning="location == 've_xuong'"
                                   decoration-success="location == 'da_tra'"/>
                            <field name="fabric_arrived" widget="boolean_toggle"
                                   string="Vải về" readonly="1" optional="show"/>
                            <field name="days_in_current_state" string="Ngày"/>
                            <field name="sla_overdue" invisible="1"/>
                            <button name="action_quick_da_tra" type="object"
                                    string="✓ Trả khách" icon="fa-check"
                                    class="btn-sm btn-success"
                                    invisible="state != 'hoan_thien' or location == 'da_tra'"
                                    title="Đồ đã hoàn thiện, khách duyệt — đánh dấu đã trả"
                                    groups="vbs_base.group_vbs_admin,vbs_base.group_vbs_sale"/>
                        </list>
                    </field>
                </page>
            </xpath>

            <!-- Tab Lệnh đặt vải — sau Đồ may -->
            <xpath expr="//page[@name='vbs_garments']" position="after">
                <page string="Lệnh đặt vải" name="vbs_fabric_orders">
                    <div class="mb-2">
                        <button name="action_create_fabric_order" type="object"
                                string="+ Tạo lệnh đặt vải"
                                class="btn btn-secondary btn-sm"
                                icon="fa-plus"/>
                    </div>
                    <field name="fabric_order_ids" readonly="1">
                        <list>
                            <field name="name" string="Số phiếu"/>
                            <field name="order_date" string="Ngày đặt"/>
                            <field name="partner_id" string="Nhà cung cấp"/>
                            <field name="state" widget="badge"
                                   decoration-info="state == 'draft'"
                                   decoration-warning="state == 'confirmed'"
                                   decoration-success="state == 'arrived'"
                                   string="Trạng thái"/>
                            <field name="arrived_line_count" string="Đã về"/>
                            <field name="pending_line_count" string="Chờ về"/>
                        </list>
                    </field>
                </page>
            </xpath>

            <!-- Notebook 2 — Thanh toán + Thông tin khác + Chữ ký -->
            <xpath expr="//sheet//notebook" position="after">
                <notebook>
                    <page string="Thanh toán" name="vbs_payments">
                        <field name="payment_ids">
                            <list editable="bottom">
                                <field name="date"/>
                                <field name="amount"/>
                                <field name="method"/>
                                <field name="note"/>
                            </list>
                        </field>
                    </page>
                    <page string="Thông tin khác" name="vbs_other_info2">
                        <group>
                            <group string="Đơn hàng">
                                <field name="client_order_ref" string="Mã đơn khách"/>
                                <field name="user_id" string="Nhân viên bán"/>
                                <field name="team_id" string="Đội bán hàng" optional="hide"/>
                            </group>
                            <group string="Thời hạn">
                                <field name="validity_date" string="Ngày hết hạn báo giá"/>
                                <field name="commitment_date" string="Ngày giao dự kiến"/>
                            </group>
                        </group>
                        <field name="note" string="Điều khoản &amp; điều kiện" placeholder="Nhập điều khoản..."/>
                    </page>
                </notebook>
            </xpath>

            <!-- Ẩn standard tabs khỏi notebook 1 bằng field-based xpath -->
            <xpath expr="//page[descendant::field[@name='client_order_ref']]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Ẩn statusbar chuẩn Odoo "Báo giá → Đơn bán hàng" — VBS dùng fashion_state -->
            <field name="state" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>

        </field>
    </record>

    <!-- Inherit sale.order list: thêm fashion_state + payment_state -->
    <record id="view_sale_order_list_vbs" model="ir.ui.view">
        <field name="name">sale.order.list.vbs</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree_with_onboarding"/>
        <field name="arch" type="xml">
            <field name="state" position="before">
                <field name="fashion_state" widget="badge"
                       decoration-info="fashion_state == 'dat_hang'"
                       decoration-warning="fashion_state == 'dang_xu_ly'"
                       decoration-primary="fashion_state == 'da_thanh_toan'"
                       decoration-success="fashion_state == 'hoan_thanh'"
                       decoration-danger="fashion_state == 'huy'"
                       optional="show"/>
                <field name="payment_state" widget="badge"
                       decoration-danger="payment_state == 'chua_tt'"
                       decoration-warning="payment_state == 'tt_1_phan'"
                       decoration-success="payment_state == 'tt_toan_bo'"
                       optional="show"/>
                <!-- Hiện currency_id để dễ phân biệt khi mix VND/USD -->
                <field name="currency_id" optional="show" string="Tiền tệ"/>
            </field>
            <!-- Bỏ sum tổng — không có ý nghĩa khi mix nhiều currency -->
            <xpath expr="//field[@name='amount_total']" position="attributes">
                <attribute name="sum"></attribute>
            </xpath>
        </field>
    </record>

</odoo>
