<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vbs_expense_form" model="ir.ui.view">
        <field name="name">vbs.expense.record.form</field>
        <field name="model">vbs.expense.record</field>
        <field name="arch" type="xml">
            <form string="Chi phí">
                <sheet>
                    <group>
                        <group string="Thông tin chi phí">
                            <field name="date"/>
                            <field name="name"/>
                            <field name="category"/>
                        </group>
                        <group string="Số tiền">
                            <field name="currency_id" invisible="1"/>
                            <field name="amount" widget="monetary"/>
                        </group>
                    </group>
                    <group string="Ghi chú">
                        <field name="note" nolabel="1" placeholder="Ghi chú thêm..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_vbs_expense_list" model="ir.ui.view">
        <field name="name">vbs.expense.record.list</field>
        <field name="model">vbs.expense.record</field>
        <field name="arch" type="xml">
            <list string="Chi phí">
                <field name="date"/>
                <field name="name"/>
                <field name="category" widget="badge"
                       decoration-warning="category == 'vai'"
                       decoration-primary="category == 'gia_cong'"
                       decoration-info="category == 'nhan_vien'"
                       decoration-muted="category == 'van_phong'"/>
                <field name="amount" widget="monetary" sum="Tổng chi phí"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_vbs_expense_graph" model="ir.ui.view">
        <field name="name">vbs.expense.record.graph</field>
        <field name="model">vbs.expense.record</field>
        <field name="arch" type="xml">
            <graph string="Chi phí theo loại" type="pie">
                <field name="category"/>
                <field name="amount" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_vbs_expense_pivot" model="ir.ui.view">
        <field name="name">vbs.expense.record.pivot</field>
        <field name="model">vbs.expense.record</field>
        <field name="arch" type="xml">
            <pivot string="Chi phí">
                <field name="date" interval="month" type="row"/>
                <field name="category" type="col"/>
                <field name="amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_vbs_expense_search" model="ir.ui.view">
        <field name="name">vbs.expense.record.search</field>
        <field name="model">vbs.expense.record</field>
        <field name="arch" type="xml">
            <search string="Tìm chi phí">
                <field name="name"/>
                <field name="category"/>
                <separator/>
                <filter string="Tháng này" name="this_month"
                        domain="[('date','&gt;=', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter string="Chi phí vải" name="vai" domain="[('category','=','vai')]"/>
                <filter string="Gia công" name="gia_cong" domain="[('category','=','gia_cong')]"/>
                <filter string="Nhân viên" name="nhan_vien" domain="[('category','=','nhan_vien')]"/>
                <group>
                    <filter string="Loại chi phí" name="group_category" context="{'group_by':'category'}"/>
                    <filter string="Tháng" name="group_month" context="{'group_by':'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_vbs_expense" model="ir.actions.act_window">
        <field name="name">Chi phí</field>
        <field name="res_model">vbs.expense.record</field>
        <field name="view_mode">list,graph,pivot,form</field>
        <field name="search_view_id" ref="view_vbs_expense_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Chưa có chi phí nào</p>
            <p>Ghi lại các khoản chi phí vải, gia công, nhân viên...</p>
        </field>
    </record>

</odoo>
