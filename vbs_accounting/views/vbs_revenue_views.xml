<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view for payment records (revenue) -->
    <record id="view_vbs_revenue_list" model="ir.ui.view">
        <field name="name">vbs.payment.record.revenue.list</field>
        <field name="model">vbs.payment.record</field>
        <field name="arch" type="xml">
            <list string="Doanh thu" create="false" delete="false" edit="false">
                <field name="date"/>
                <field name="partner_id" string="Khách hàng"/>
                <field name="order_id" string="Đơn hàng"/>
                <field name="method" widget="badge"
                       decoration-success="method == 'transfer'"
                       decoration-info="method == 'card'"
                       decoration-warning="method == 'cash'"/>
                <field name="amount" widget="monetary" sum="Tổng thu"/>
                <field name="note" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_vbs_revenue_graph" model="ir.ui.view">
        <field name="name">vbs.payment.record.revenue.graph</field>
        <field name="model">vbs.payment.record</field>
        <field name="arch" type="xml">
            <graph string="Doanh thu theo tháng" type="bar">
                <field name="date" interval="month"/>
                <field name="amount" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_vbs_revenue_pivot" model="ir.ui.view">
        <field name="name">vbs.payment.record.revenue.pivot</field>
        <field name="model">vbs.payment.record</field>
        <field name="arch" type="xml">
            <pivot string="Doanh thu">
                <field name="date" interval="month" type="row"/>
                <field name="method" type="col"/>
                <field name="amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_vbs_revenue_search" model="ir.ui.view">
        <field name="name">vbs.payment.record.revenue.search</field>
        <field name="model">vbs.payment.record</field>
        <field name="arch" type="xml">
            <search string="Tìm doanh thu">
                <field name="partner_id"/>
                <field name="order_id"/>
                <separator/>
                <filter string="Tiền mặt" name="cash" domain="[('method','=','cash')]"/>
                <filter string="Chuyển khoản" name="transfer" domain="[('method','=','transfer')]"/>
                <filter string="Thẻ" name="card" domain="[('method','=','card')]"/>
                <group>
                    <filter string="Tháng" name="group_month" context="{'group_by':'date:month'}"/>
                    <filter string="Phương thức" name="group_method" context="{'group_by':'method'}"/>
                    <filter string="Khách hàng" name="group_partner" context="{'group_by':'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_vbs_revenue" model="ir.actions.act_window">
        <field name="name">Doanh thu</field>
        <field name="res_model">vbs.payment.record</field>
        <field name="view_mode">list,graph,pivot</field>
        <field name="view_ids" eval="[(5,), (0,0,{'view_mode':'list','view_id':ref('view_vbs_revenue_list')}), (0,0,{'view_mode':'graph','view_id':ref('view_vbs_revenue_graph')}), (0,0,{'view_mode':'pivot','view_id':ref('view_vbs_revenue_pivot')})]"/>
        <field name="search_view_id" ref="view_vbs_revenue_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Chưa có khoản thu nào</p>
            <p>Các khoản thanh toán từ đơn hàng sẽ hiển thị ở đây.</p>
        </field>
    </record>

</odoo>
