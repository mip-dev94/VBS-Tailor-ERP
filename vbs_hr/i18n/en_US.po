#. module: vbs_hr
#: model_terms:ir.ui.view,arch_db:vbs_hr.view_employee_kanban_vbs
msgid "<i class=\"fa fa-fw me-2 fa-shield text-primary\" title=\"VBS Roles\"/>"
msgstr "<i class=\"fa fa-fw me-2 fa-shield text-primary\" title=\"VBS Roles\"/>"

#. module: vbs_hr
#: model_terms:ir.ui.view,arch_db:vbs_hr.view_employee_form_vbs_roles
msgid ""
"<strong>Chưa liên kết tài khoản.</strong>\n"
"                        Nhân viên này cần được gán User (trường \"Related User\" ở tab Work Information) trước khi phân quyền."
msgstr ""
"<strong>No linked account.</strong>\n"
"                        This employee needs a User assigned (\"Related User\" field in Work Information tab) before setting roles."

#. module: vbs_hr
#: model_terms:ir.ui.view,arch_db:vbs_hr.view_employee_form_vbs_roles
msgid "<strong>Kho:</strong> Quản lý tồn kho vải, đánh dấu vải về (DV03→DV04)"
msgstr "<strong>Warehouse:</strong> Manage fabric stock, mark fabric arrived (DV03→DV04)"

#. module: vbs_hr
#: model_terms:ir.ui.view,arch_db:vbs_hr.view_employee_form_vbs_roles
msgid ""
"<strong>Kế toán:</strong> Duyệt đặt vải (DV01→DV02), xem pricing, quản lý "
"thanh toán"
msgstr ""
"<strong>Accountant:</strong> Approve fabric orders (DV01→DV02), view pricing, manage payments"

#. module: vbs_hr
#: model_terms:ir.ui.view,arch_db:vbs_hr.view_employee_form_vbs_roles
msgid ""
"<strong>Quản trị VBS:</strong> Toàn quyền — quản lý user, huỷ đơn, cấu hình "
"hệ thống"
msgstr ""
"<strong>VBS Admin:</strong> Full access — manage users, cancel orders, system configuration"

#. module: vbs_hr
#: model_terms:ir.ui.view,arch_db:vbs_hr.view_employee_form_vbs_roles
msgid ""
"<strong>Sale:</strong> Tạo đơn hàng, tạo đặt vải, xem planning (không sửa), "
"liên hệ khách"
msgstr ""
"<strong>Sales:</strong> Create orders, create fabric orders, view planning (read-only), contact customers"

#. module: vbs_hr
#: model_terms:ir.ui.view,arch_db:vbs_hr.view_employee_form_vbs_roles
msgid "<strong>Văn phòng:</strong> Sửa planning, liên hệ khách, theo dõi đồ"
msgstr "<strong>Office:</strong> Edit planning, contact customers, track garments"

#. module: vbs_hr
#: model_terms:ir.ui.view,arch_db:vbs_hr.view_employee_form_vbs_roles
msgid ""
"<strong>Xưởng:</strong> Cập nhật tiến độ sản xuất, sửa planning, cập nhật "
"bước công đoạn"
msgstr ""
"<strong>Workshop:</strong> Update production progress, edit planning, update production stages"

