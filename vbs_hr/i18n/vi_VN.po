#. module: vbs_hr
#: model_terms:ir.ui.view,arch_db:vbs_hr.view_employee_form_vbs_roles
msgid ""
"<strong>Chưa liên kết tài khoản.</strong>\n"
"                        Nhân viên này cần được gán User (trường \"Related User\" ở tab Work Information) trước khi phân quyền."
msgstr ""

#. module: vbs_hr
#: model_terms:ir.ui.view,arch_db:vbs_hr.view_employee_form_vbs_roles
msgid "<strong>Kho:</strong> Quản lý tồn kho vải, đánh dấu vải về (DV03→DV04)"
msgstr ""

#. module: vbs_hr
#: model_terms:ir.ui.view,arch_db:vbs_hr.view_employee_form_vbs_roles
msgid ""
"<strong>Kế toán:</strong> Duyệt đặt vải (DV01→DV02), xem pricing, quản lý "
"thanh toán"
msgstr ""

#. module: vbs_hr
#: model_terms:ir.ui.view,arch_db:vbs_hr.view_employee_form_vbs_roles
msgid ""
"<strong>Quản trị VBS:</strong> Toàn quyền — quản lý user, huỷ đơn, cấu hình "
"hệ thống"
msgstr ""

#. module: vbs_hr
#: model_terms:ir.ui.view,arch_db:vbs_hr.view_employee_form_vbs_roles
msgid ""
"<strong>Sale:</strong> Tạo đơn hàng, tạo đặt vải, xem planning (không sửa), "
"liên hệ khách"
msgstr ""

#. module: vbs_hr
#: model_terms:ir.ui.view,arch_db:vbs_hr.view_employee_form_vbs_roles
msgid "<strong>Văn phòng:</strong> Sửa planning, liên hệ khách, theo dõi đồ"
msgstr ""

#. module: vbs_hr
#: model_terms:ir.ui.view,arch_db:vbs_hr.view_employee_form_vbs_roles
msgid ""
"<strong>Xưởng:</strong> Cập nhật tiến độ sản xuất, sửa planning, cập nhật "
"bước công đoạn"
msgstr ""

