<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vbs_product_form" model="ir.ui.view">
        <field name="name">vbs.product.form</field>
        <field name="model">vbs.product</field>
        <field name="arch" type="xml">
            <form string="Sản phẩm">
                <header>
                    <button name="action_mark_ready" type="object"
                            string="Đánh dấu sẵn bán" class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_archive" type="object"
                            string="Ngừng bán"
                            invisible="state in ('archived',)"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,ready,sold,archived"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object"
                                name="action_mark_ready" icon="fa-check-circle"
                                invisible="state != 'draft'">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="total_available" nolabel="1"/>
                                </span>
                                <span class="o_stat_text">Khả dụng</span>
                            </div>
                        </button>
                        <button class="oe_stat_button" icon="fa-percent"
                                type="button" disabled="1"
                                invisible="profit_margin_pct == 0">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value"
                                      decoration-success="profit_margin_pct >= 30"
                                      decoration-warning="profit_margin_pct &gt;= 10 and profit_margin_pct &lt; 30"
                                      decoration-danger="profit_margin_pct &lt; 10">
                                    <field name="profit_margin_pct"
                                           decoration-success="profit_margin_pct >= 30"
                                           decoration-warning="profit_margin_pct &gt;= 10 and profit_margin_pct &lt; 30"
                                           decoration-danger="profit_margin_pct &lt; 10"
                                           nolabel="1"/>%
                                </span>
                                <span class="o_stat_text">Biên LN</span>
                            </div>
                        </button>
                    </div>

                    <field name="image_1920" widget="image" class="oe_avatar"
                           options="{'preview_image': 'image_128'}"/>
                    <div class="oe_title">
                        <span class="text-muted me-2">
                            <field name="code" readonly="1"/>
                        </span>
                        <div class="mb-1">
                            <field name="product_type" widget="badge"
                                   decoration-primary="product_type == 'b2b_ban'"
                                   decoration-warning="product_type == 'b2b_gia_cong'"
                                   decoration-success="product_type == 'b2c'"
                                   decoration-muted="product_type == 'nhap'"/>
                        </div>
                        <h1><field name="name" placeholder="Tên sản phẩm..."/></h1>
                        <div class="text-muted">
                            <field name="sku" placeholder="SKU / mã nội bộ..."/>
                        </div>
                    </div>

                    <group>
                        <group string="Thuộc tính sản phẩm">
                            <field name="product_type"/>
                            <field name="garment_type"/>
                            <field name="fabric_type_id"/>
                            <field name="size"/>
                            <field name="color"/>
                            <field name="weight_grams"/>
                        </group>
                        <group string="Giá bán theo hình thức">
                            <field name="currency_id" invisible="1"/>
                            <field name="list_price" widget="monetary" string="Giá lẻ"/>
                            <field name="price_bo_2" widget="monetary"
                                   invisible="garment_category != 'ao'"/>
                            <field name="price_bo_3" widget="monetary"
                                   invisible="garment_category != 'ao'"/>
                            <field name="profit_amount" widget="monetary" readonly="1"
                                   groups="vbs_base.group_vbs_admin,vbs_base.group_vbs_accountant"/>
                            <field name="profit_margin_pct" readonly="1"
                                   decoration-success="profit_margin_pct >= 30"
                                   decoration-warning="profit_margin_pct &gt;= 10 and profit_margin_pct &lt; 30"
                                   decoration-danger="profit_margin_pct &lt; 10 and profit_margin_pct != 0"
                                   groups="vbs_base.group_vbs_admin,vbs_base.group_vbs_accountant"/>
                            <field name="total_available" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Giá vốn" name="costing"
                              groups="vbs_base.group_vbs_admin,vbs_base.group_vbs_accountant">
                            <group>
                                <group string="Chi phí cấu thành">
                                    <field name="cost_fabric" widget="monetary"/>
                                    <field name="cost_labor" widget="monetary"/>
                                    <field name="cost_other" widget="monetary"/>
                                    <div colspan="2" class="mt-2">
                                        <button name="action_fill_cost_from_breakdown"
                                                type="object" string="→ Tính giá vốn từ breakdown"
                                                class="btn btn-secondary btn-sm"/>
                                    </div>
                                </group>
                                <group string="Tổng kết">
                                    <field name="cost_price" widget="monetary"/>
                                    <field name="profit_amount" widget="monetary" readonly="1"/>
                                    <field name="profit_margin_pct" readonly="1"
                                           decoration-success="profit_margin_pct >= 30"
                                           decoration-warning="profit_margin_pct &gt;= 10 and profit_margin_pct &lt; 30"
                                           decoration-danger="profit_margin_pct &lt; 10 and profit_margin_pct != 0"/>
                                </group>
                            </group>
                        </page>

                        <page string="Tồn kho" name="stock">
                            <field name="stock_ids">
                                <list editable="bottom">
                                    <field name="partner_store_id"/>
                                    <field name="quantity_on_hand"/>
                                    <field name="quantity_reserved" readonly="1"/>
                                    <field name="quantity_available" readonly="1"/>
                                    <field name="date_received"/>
                                    <field name="note" optional="hide"/>
                                </list>
                            </field>
                        </page>

                        <page string="Mô tả" name="description">
                            <field name="detail" placeholder="Mô tả chi tiết sản phẩm..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_vbs_product_list" model="ir.ui.view">
        <field name="name">vbs.product.list</field>
        <field name="model">vbs.product</field>
        <field name="arch" type="xml">
            <list string="Sản phẩm">
                <field name="code"/>
                <field name="name"/>
                <field name="product_type" widget="badge"
                       decoration-primary="product_type == 'b2b_ban'"
                       decoration-warning="product_type == 'b2b_gia_cong'"
                       decoration-success="product_type == 'b2c'"
                       decoration-muted="product_type == 'nhap'"/>
                <field name="garment_type"/>
                <field name="size" optional="show"/>
                <field name="color" optional="show"/>
                <field name="list_price" widget="monetary" string="Giá bán"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="cost_price" widget="monetary" optional="hide"
                       groups="vbs_base.group_vbs_admin,vbs_base.group_vbs_accountant"/>
                <field name="profit_margin_pct" optional="show" string="Biên LN (%)"
                       decoration-success="profit_margin_pct >= 30"
                       decoration-warning="profit_margin_pct &gt;= 10 and profit_margin_pct &lt; 30"
                       decoration-danger="profit_margin_pct &lt; 10 and profit_margin_pct != 0"
                       groups="vbs_base.group_vbs_admin,vbs_base.group_vbs_accountant"/>
                <field name="total_available" string="Khả dụng"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'ready'"
                       decoration-muted="state == 'sold'"
                       decoration-danger="state == 'archived'"/>
            </list>
        </field>
    </record>

    <record id="view_vbs_product_kanban" model="ir.ui.view">
        <field name="name">vbs.product.kanban</field>
        <field name="model">vbs.product</field>
        <field name="arch" type="xml">
            <kanban default_group_by="product_type">
                <field name="id"/>
                <field name="name"/>
                <field name="code"/>
                <field name="product_type"/>
                <field name="list_price"/>
                <field name="cost_price"/>
                <field name="profit_margin_pct"/>
                <field name="currency_id"/>
                <field name="total_available"/>
                <field name="state"/>
                <field name="garment_type"/>
                <field name="image_128"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_card_content d-flex">
                            <div class="o_kanban_image me-3">
                                <img t-att-src="'/web/image/vbs.product/' + record.id.raw_value + '/image_128'"
                                     alt="Product" class="rounded"/>
                            </div>
                            <div class="oe_kanban_details flex-grow-1">
                                <strong><field name="name"/></strong>
                                <div class="text-muted small"><field name="code"/></div>
                                <div class="mt-1">
                                    <span class="fw-bold">
                                        <field name="list_price" widget="monetary"/>
                                    </span>
                                </div>
                                <div class="text-muted small mt-1">
                                    Khả dụng: <field name="total_available"/>
                                    <t t-if="record.profit_margin_pct.raw_value">
                                        · LN: <field name="profit_margin_pct"/>%
                                    </t>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_vbs_product_search" model="ir.ui.view">
        <field name="name">vbs.product.search</field>
        <field name="model">vbs.product</field>
        <field name="arch" type="xml">
            <search string="Tìm sản phẩm">
                <field name="name"/>
                <field name="code"/>
                <field name="sku"/>
                <field name="garment_type"/>
                <field name="fabric_type_id"/>
                <separator/>
                <filter string="B2B Bán" name="b2b_ban" domain="[('product_type','=','b2b_ban')]"/>
                <filter string="B2B Gia công" name="b2b_gia_cong" domain="[('product_type','=','b2b_gia_cong')]"/>
                <filter string="B2C" name="b2c" domain="[('product_type','=','b2c')]"/>
                <filter string="Nháp / Mẫu" name="nhap" domain="[('product_type','=','nhap')]"/>
                <separator/>
                <filter string="Nháp" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Sẵn bán" name="ready" domain="[('state','=','ready')]"/>
                <filter string="Còn hàng" name="has_stock" domain="[('total_available','>',0)]"/>
                <filter string="Biên LN ≥ 30%" name="high_margin"
                        domain="[('profit_margin_pct','>=',30)]"/>
                <group>
                    <filter string="Loại SP" name="group_product_type" context="{'group_by': 'product_type'}"/>
                    <filter string="Trạng thái" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Loại đồ" name="group_garment_type" context="{'group_by': 'garment_type'}"/>
                    <filter string="Loại vải" name="group_fabric" context="{'group_by': 'fabric_type_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_vbs_product" model="ir.actions.act_window">
        <field name="name">Tất cả sản phẩm</field>
        <field name="res_model">vbs.product</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_vbs_product_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Chưa có sản phẩm nào</p>
            <p>Tạo sản phẩm thủ công hoặc publish từ đồ may đã hoàn thiện.</p>
        </field>
    </record>

    <record id="action_vbs_product_b2b_ban" model="ir.actions.act_window">
        <field name="name">B2B — Bán thành phẩm</field>
        <field name="res_model">vbs.product</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('product_type','=','b2b_ban')]</field>
        <field name="context">{'default_product_type': 'b2b_ban'}</field>
        <field name="search_view_id" ref="view_vbs_product_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Chưa có sản phẩm B2B Bán nào</p>
        </field>
    </record>

    <record id="action_vbs_product_b2b_gia_cong" model="ir.actions.act_window">
        <field name="name">B2B — Gia công CMT</field>
        <field name="res_model">vbs.product</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('product_type','=','b2b_gia_cong')]</field>
        <field name="context">{'default_product_type': 'b2b_gia_cong'}</field>
        <field name="search_view_id" ref="view_vbs_product_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Chưa có sản phẩm B2B Gia công nào</p>
        </field>
    </record>

    <record id="action_vbs_product_b2c" model="ir.actions.act_window">
        <field name="name">B2C — Thành phẩm</field>
        <field name="res_model">vbs.product</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('product_type','=','b2c')]</field>
        <field name="context">{'default_product_type': 'b2c'}</field>
        <field name="search_view_id" ref="view_vbs_product_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Chưa có sản phẩm B2C nào</p>
        </field>
    </record>

    <record id="action_vbs_product_nhap" model="ir.actions.act_window">
        <field name="name">Nháp / Mẫu</field>
        <field name="res_model">vbs.product</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('product_type','=','nhap')]</field>
        <field name="context">{'default_product_type': 'nhap'}</field>
        <field name="search_view_id" ref="view_vbs_product_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Chưa có sản phẩm nháp nào</p>
        </field>
    </record>

</odoo>
