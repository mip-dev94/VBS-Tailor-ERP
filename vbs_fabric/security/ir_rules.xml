<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_fabric_stock_warehouse_write" model="ir.rule">
        <field name="name">VBS Fabric Stock: Warehouse write</field>
        <field name="model_id" ref="model_vbs_fabric_stock"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('vbs_base.group_vbs_warehouse'))]"/>
        <field name="perm_read">1</field>
        <field name="perm_write">1</field>
        <field name="perm_create">1</field>
        <field name="perm_unlink">0</field>
    </record>

    <record id="rule_fabric_stock_admin_write" model="ir.rule">
        <field name="name">VBS Fabric Stock: Admin full</field>
        <field name="model_id" ref="model_vbs_fabric_stock"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('vbs_base.group_vbs_admin'))]"/>
        <field name="perm_read">1</field>
        <field name="perm_write">1</field>
        <field name="perm_create">1</field>
        <field name="perm_unlink">1</field>
    </record>
</odoo>
