<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vbs_fabric_type_list" model="ir.ui.view">
        <field name="name">vbs.fabric.type.list</field>
        <field name="model">vbs.fabric.type</field>
        <field name="arch" type="xml">
            <list string="Danh mục vải" editable="bottom">
                <field name="code"/>
                <field name="name"/>
                <field name="fabric_brand"/>
                <field name="price_per_meter"/>
                <field name="note" optional="show"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_vbs_fabric_type_form" model="ir.ui.view">
        <field name="name">vbs.fabric.type.form</field>
        <field name="model">vbs.fabric.type</field>
        <field name="arch" type="xml">
            <form string="Loại vải">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="display_name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="fabric_brand"/>
                        </group>
                        <group>
                            <field name="price_per_meter"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Ghi chú">
                        <field name="note" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_vbs_fabric_type_search" model="ir.ui.view">
        <field name="name">vbs.fabric.type.search</field>
        <field name="model">vbs.fabric.type</field>
        <field name="arch" type="xml">
            <search string="Tìm loại vải">
                <field name="code"/>
                <field name="name"/>
                <field name="fabric_brand"/>
                <filter string="Đang dùng" name="active" domain="[('active','=',True)]"/>
                <group>
                    <filter string="Hãng vải" name="group_brand" domain="[]"
                            context="{'group_by': 'fabric_brand'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_vbs_fabric_type" model="ir.actions.act_window">
        <field name="name">Danh mục vải</field>
        <field name="res_model">vbs.fabric.type</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Chưa có loại vải nào</p>
            <p>Thêm các loại vải VBS đang sử dụng để tính giá tự động.</p>
        </field>
    </record>

</odoo>
